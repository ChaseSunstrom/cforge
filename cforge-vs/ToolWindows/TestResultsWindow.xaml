<UserControl x:Class="CforgeVS.TestResultsWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:theming="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Imaging"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="700"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
             theming:ImageThemingUtilities.ImageBackgroundColor="{DynamicResource {x:Static vsshell:VsColors.ToolWindowBackgroundKey}}">

    <UserControl.Resources>
        <!-- TreeView Item Style -->
        <Style x:Key="TestTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=OneWay}"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
        </Style>

        <!-- Toolbar Button Style -->
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarTextActiveKey}}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseDownBackgroundGradientKey}}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toolbar ToggleButton Style -->
        <Style x:Key="ToolbarToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarTextActiveKey}}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarSelectedKey}}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientKey}}"
                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="4,2">
                <Button x:Name="RunAllButton" Style="{StaticResource ToolbarBtn}" ToolTip="Run All Tests" Click="RunAllButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Run}"/>
                        <TextBlock Text="Run All" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="RunFailedButton" Style="{StaticResource ToolbarBtn}" ToolTip="Run Failed Tests" Click="RunFailedButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.StatusError}"/>
                        <TextBlock Text="Run Failed" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="StopButton" Style="{StaticResource ToolbarBtn}" ToolTip="Stop Test Run" Click="StopButton_Click"
                        IsEnabled="False">
                    <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.Stop}"/>
                </Button>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,4"/>
                <ToggleButton x:Name="ShowPassedToggle" Style="{StaticResource ToolbarToggleBtn}" IsChecked="True"
                              ToolTip="Show Passed Tests" Click="FilterToggle_Click">
                    <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.StatusOK}"/>
                </ToggleButton>
                <ToggleButton x:Name="ShowFailedToggle" Style="{StaticResource ToolbarToggleBtn}" IsChecked="True"
                              ToolTip="Show Failed Tests" Click="FilterToggle_Click">
                    <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.StatusError}"/>
                </ToggleButton>
                <ToggleButton x:Name="ShowSkippedToggle" Style="{StaticResource ToolbarToggleBtn}" IsChecked="True"
                              ToolTip="Show Skipped Tests" Click="FilterToggle_Click">
                    <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.StatusWarning}"/>
                </ToggleButton>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,4"/>
                <Button Style="{StaticResource ToolbarBtn}" ToolTip="Clear Results" Click="ClearButton_Click">
                    <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.ClearWindowContent}"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Summary Bar -->
        <Border Grid.Row="1" x:Name="SummaryBar" Padding="8,6"
                Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientKey}}"
                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Passed Count -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                    <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.StatusOK}"
                                        VerticalAlignment="Center"/>
                    <TextBlock x:Name="PassedCountText" Text="0" FontWeight="SemiBold" Margin="4,0,0,0"
                               Foreground="#28a745" VerticalAlignment="Center"/>
                    <TextBlock Text=" passed" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Failed Count -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                    <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.StatusError}"
                                        VerticalAlignment="Center"/>
                    <TextBlock x:Name="FailedCountText" Text="0" FontWeight="SemiBold" Margin="4,0,0,0"
                               Foreground="#dc3545" VerticalAlignment="Center"/>
                    <TextBlock Text=" failed" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Skipped Count -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0">
                    <imaging:CrispImage Width="16" Height="16" Moniker="{x:Static catalog:KnownMonikers.StatusWarning}"
                                        VerticalAlignment="Center"/>
                    <TextBlock x:Name="SkippedCountText" Text="0" FontWeight="SemiBold" Margin="4,0,0,0"
                               Foreground="#ffc107" VerticalAlignment="Center"/>
                    <TextBlock Text=" skipped" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Total Count -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <TextBlock x:Name="TotalCountText" Text="0" FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" total" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Duration -->
                <TextBlock Grid.Column="5" x:Name="DurationText" Text=""
                           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="1" x:Name="TestProgressBar" Height="4" Margin="0,-4,0,0"
                     VerticalAlignment="Bottom" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"/>

        <!-- Main Content - Split View -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Test Tree -->
            <TreeView Grid.Column="0" x:Name="TestTree"
                      Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
                      BorderThickness="0" Padding="4"
                      ItemContainerStyle="{StaticResource TestTreeItemStyle}"
                      SelectedItemChanged="TestTree_SelectedItemChanged"
                      MouseDoubleClick="TestTree_MouseDoubleClick">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <imaging:CrispImage Width="16" Height="16" Margin="0,0,6,0"
                                                Moniker="{Binding ImageMoniker}"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
                            <TextBlock Text="{Binding Badge}" FontSize="10" Margin="6,0,0,0"
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"/>

            <!-- Details Panel -->
            <Border Grid.Column="2" Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">
                <Grid>
                    <!-- Test Details -->
                    <ScrollViewer x:Name="DetailsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12">
                            <!-- Test Name -->
                            <TextBlock x:Name="DetailTestName" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <!-- Test Status -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <imaging:CrispImage x:Name="DetailStatusIcon" Width="16" Height="16"
                                                    Moniker="{x:Static catalog:KnownMonikers.StatusOK}"/>
                                <TextBlock x:Name="DetailStatusText" Text="Passed" Margin="6,0,0,0"
                                           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
                                <TextBlock x:Name="DetailDurationText" Text="" Margin="12,0,0,0"
                                           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
                            </StackPanel>

                            <!-- Source Location -->
                            <TextBlock x:Name="DetailSourceText" Margin="0,0,0,12"
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                                       Cursor="Hand" MouseLeftButtonUp="DetailSourceText_Click">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Error Message -->
                            <TextBlock Text="Error Message" FontWeight="SemiBold" Margin="0,0,0,4"
                                       x:Name="ErrorMessageHeader" Visibility="Collapsed"
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
                            <Border x:Name="ErrorMessagePanel" Visibility="Collapsed"
                                    Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientKey}}"
                                    CornerRadius="3" Padding="8" Margin="0,0,0,12">
                                <TextBox x:Name="DetailErrorMessage" IsReadOnly="True" BorderThickness="0"
                                         Background="Transparent" TextWrapping="Wrap"
                                         FontFamily="Consolas" FontSize="11"
                                         Foreground="#dc3545"/>
                            </Border>

                            <!-- Stack Trace -->
                            <TextBlock Text="Stack Trace" FontWeight="SemiBold" Margin="0,0,0,4"
                                       x:Name="StackTraceHeader" Visibility="Collapsed"
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
                            <Border x:Name="StackTracePanel" Visibility="Collapsed"
                                    Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientKey}}"
                                    CornerRadius="3" Padding="8" MaxHeight="200">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBox x:Name="DetailStackTrace" IsReadOnly="True" BorderThickness="0"
                                             Background="Transparent" TextWrapping="NoWrap"
                                             FontFamily="Consolas" FontSize="11"
                                             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
                                </ScrollViewer>
                            </Border>

                            <!-- Output -->
                            <TextBlock Text="Standard Output" FontWeight="SemiBold" Margin="0,12,0,4"
                                       x:Name="OutputHeader" Visibility="Collapsed"
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
                            <Border x:Name="OutputPanel" Visibility="Collapsed"
                                    Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientKey}}"
                                    CornerRadius="3" Padding="8" MaxHeight="150">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBox x:Name="DetailOutput" IsReadOnly="True" BorderThickness="0"
                                             Background="Transparent" TextWrapping="NoWrap"
                                             FontFamily="Consolas" FontSize="11"
                                             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Empty State for Details -->
                    <StackPanel x:Name="DetailsEmptyState" Visibility="Visible"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Select a test to view details" FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Empty State for Tree -->
        <StackPanel Grid.Row="2" x:Name="EmptyState" Visibility="Visible"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
            <imaging:CrispImage Width="48" Height="48" Opacity="0.5"
                                Moniker="{x:Static catalog:KnownMonikers.StatusInformation}"
                                HorizontalAlignment="Center"/>
            <TextBlock Text="No test results" FontSize="14" Margin="0,12,0,4"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
            <TextBlock Text="Run tests to see results here" FontSize="11"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
        </StackPanel>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientKey}}"
                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}" BorderThickness="0,1,0,0"
                Padding="8,4">
            <TextBlock x:Name="StatusText" Text="Ready" FontSize="11"
                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
